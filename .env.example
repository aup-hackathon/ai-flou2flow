# === LLM Configuration ===
# Provider: "mistral" (Mistral AI API) or "ollama" (local Ollama)
LLM_PROVIDER=mistral

# Mistral AI API Key (get one at https://console.mistral.ai/)
MISTRAL_API_KEY=your_api_key_here

# Model name
# For Mistral API: "mistral-small-latest", "open-mistral-7b", "mistral-tiny"
# For Ollama: "mistral:7b-instruct"
LLM_MODEL=mistral-small-latest

# Ollama base URL (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# === Server Configuration ===
HOST=0.0.0.0
PORT=8000
